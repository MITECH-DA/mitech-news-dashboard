# 이 파일을 복사해서 .env로 저장한 뒤 실제 값을 채워넣으세요.
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 추가 권장).

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# 네이버 뉴스 검색 API (https://developers.naver.com 에서 애플리케이션 등록 후 발급)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# SQLite DB 파일 경로 (기본값 사용 시 생략 가능)
DB_PATH=mitech_news.db
